# ==========================================
# SoulSanctuary v2.0 - Environment Variables Template
# Copy this to .env.local and fill in your values
# .env.local is in .gitignore and won't be committed
# ==========================================

# ------------------------------------------
# REQUIRED: OpenRouter AI (for therapy AI features)
# Get key at: https://openrouter.ai/keys
# ------------------------------------------
OPENROUTER_API_KEY=your-openrouter-api-key-here

# OpenRouter model preferences (optional, defaults shown)
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_FALLBACK_MODEL=openai/gpt-4o-mini

# ------------------------------------------
# REQUIRED: Database (Drizzle ORM)
# Choose ONE: PostgreSQL (recommended) or SQLite
# ------------------------------------------

# Option A: PostgreSQL (Production)
# Get free DB at: https://neon.tech or https://supabase.com
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Option B: SQLite (Local Development)
# DATABASE_URL=file:./soulsanctuary.db

# ------------------------------------------
# REQUIRED: Authentication (Clerk recommended)
# Get keys at: https://dashboard.clerk.com
# ------------------------------------------
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here
CLERK_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# JWT Secret for custom auth
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-long

# ------------------------------------------
# OAuth Providers (for social login)
# Google OAuth: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# GitHub OAuth: https://github.com/settings/developers
GITHUB_CLIENT_ID=your-github-client-id

# Apple Sign In: https://developer.apple.com/account/resources/identifiers/list/serviceId
APPLE_CLIENT_ID=com.yourcompany.soulsanctuary

# ------------------------------------------
# REQUIRED: Encryption (End-to-End)
# Generate with: openssl rand -base64 32
# ------------------------------------------
ENCRYPTION_KEY=your-32-byte-encryption-key-here
ENCRYPTION_IV=your-16-byte-iv-here

# ------------------------------------------
# SECURITY: CORS Configuration
# Comma-separated list of allowed origins
# ------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,capacitor://localhost,ionic://localhost

# ------------------------------------------
# SECURITY: Content Security Policy
# Additional trusted domains for CSP (comma-separated)
# ------------------------------------------
CSP_ALLOWED_DOMAINS=

# ------------------------------------------
# OPTIONAL: Push Notifications (Capacitor)
# Firebase Cloud Messaging for Android
# ------------------------------------------
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your-client-id
FIREBASE_CLIENT_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/...

# Apple Push Notification Service (APNs)
# Get from Apple Developer Portal → Certificates, Identifiers & Profiles
APNS_KEY_ID=YOUR_KEY_ID
APNS_TEAM_ID=YOUR_TEAM_ID
APNS_BUNDLE_ID=com.soulsanctuary.app
APNS_P8_FILE_PATH=./AuthKey_YOURKEYID.p8

# ------------------------------------------
# OPTIONAL: Analytics & Monitoring
# ------------------------------------------
# Sentry (Error tracking) - https://sentry.io
SENTRY_DSN=https://your-sentry-dsn-here

# Log level (error, warn, info, http, debug)
LOG_LEVEL=info

# ------------------------------------------
# OPTIONAL: Rate Limiting Overrides
# ------------------------------------------
# General API rate limit (requests per minute)
RATE_LIMIT_GENERAL=100

# AI endpoint rate limit (requests per hour)
RATE_LIMIT_AI=20

# Crisis endpoint rate limit (requests per minute)
RATE_LIMIT_CRISIS=10

# ------------------------------------------
# Server Configuration
# ------------------------------------------
PORT=3001
NODE_ENV=development

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:5173

# ------------------------------------------
# INSTRUCTIONS:
# 1. Copy this file to .env.local
# 2. Fill in your real API keys in .env.local
# 3. Never commit .env.local to git
# 4. Keep your real keys in a password manager
# ==========================================
